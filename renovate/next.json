{
  "extends": ["github>iamvikshan/.github//renovate/typescript"],
  "packageRules": [
    {
      "description": "Group core React engine, icons, and shared state management tools",
      "matchPackageNames": ["react", "react-dom", "react-is", "zustand"],
      "matchPackagePatterns": ["^react-icons", "^framer-motion", "^motion"],
      "labels": ["dependencies", "react"]
    },
    {
      "description": "Group Next.js core frameworks and common utilities across platforms",
      "matchPackageNames": ["next"],
      "matchPackagePatterns": ["^next-", "^@vercel/", "next-themes"],
      "labels": ["dependencies", "nextjs"]
    },
    {
      "description": "Unified Database Group: Combines MongoDB and Supabase into a singular backend update track",
      "matchPackageNames": ["mongodb", "supabase"],
      "matchPackagePatterns": ["^@supabase/"],
      "groupName": "databases and backend-as-a-service",
      "labels": ["dependencies", "database"]
    },
    {
      "description": "Shared Data Visualization tracking for projects using ApexCharts or Recharts",
      "matchPackageNames": ["apexcharts", "react-apexcharts", "recharts"],
      "groupName": "data visualization frameworks",
      "labels": ["dependencies", "charts"]
    }
  ]
}
