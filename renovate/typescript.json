{
  "extends": ["github>iamvikshan/.github//renovate/base"],
  "packageRules": [
    {
      "groupName": "linters and formatters",
      "matchPackageNames": [
        "husky",
        "oxlint",
        "oxlint-tsgolint",
        "oxfmt",
        "/^oxlint/",
        "/^oxfmt/"
      ]
    },
    {
      "groupName": "TypeScript and types",
      "matchPackageNames": ["typescript", "/^@types/"]
    }
  ]
}
