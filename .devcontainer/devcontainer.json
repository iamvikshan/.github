{
  "name": "Ubuntu + Bun",
  "image": "vikshan/ubuntu-bun-ai:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "WakaTime.vscode-wakatime",
        "coderabbit.coderabbit-vscode",
        "tamasfe.even-better-toml",
        "oxc.oxc-vscode"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "remoteUser": "root",
  "postCreateCommand": "bun i && bun bs"
}
